{
  "name": "salus-zero",
  "version": "1.0.0-hackathon",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "SALUS Zero — a clinical training simulator for medicine where nothing is available.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "check:ref": "sh scripts/check-ref.sh",
    "build": "pnpm check:ref && pnpm typecheck && vitest run && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "wrangler pages dev",
    "deploy": "pnpm build && wrangler pages deploy",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.0.0"
  }
}
